from pyspark.sql import SparkSession
from pyspark.sql.functions import col

spark = SparkSession.builder \
    .appName("ViolenciaGeneroBatch") \
    .getOrCreate()

# Cargar dataset real
df = spark.read.csv("violencia_genero.csv", header=True, inferSchema=True)

# Ver columnas reales
print("COLUMNAS DEL DATASET:")
print(df.columns)

# Mostrar datos
df.show(5)

# Limpieza
df = df.dropna()

# Ejemplo de transformación (ajusta según columnas reales)
# Supongamos que existen:
# 'sexo', 'tipo_violencia', 'departamento'

# Análisis exploratorio (EDA)
print("Total registros:")
print(df.count())

print("Casos por sexo:")
df.groupBy("sexo").count().show()

print("Casos por tipo de violencia:")
df.groupBy("tipo_violencia").count().show()

print("Casos por departamento:")
df.groupBy("departamento").count().show()


